@model ColegioSanJose.Models.Alumno

@{
    ViewData["Title"] = "Eliminar Alumno";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamat-triangle"></i> Confirmar Eliminación</h4>
                </div>
                <div class="card-body">
                    <h5 class="text-center mb-4">¿Está seguro de que desea eliminar permanentemente a este alumno?</h5>
                    
                    <div class="bg-light p-3 rounded mb-4">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Nombre:</dt>
                            <dd class="col-sm-8 font-weight-bold">@Html.DisplayFor(model => model.Nombre)</dd>

                            <dt class="col-sm-4 text-muted">Apellido:</dt>
                            <dd class="col-sm-8 font-weight-bold">@Html.DisplayFor(model => model.Apellido)</dd>

                            <dt class="col-sm-4 text-muted">Fecha de Nacimiento:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaNacimiento)</dd>

                            <dt class="col-sm-4 text-muted">Grado:</dt>
                            <dd class="col-sm-8">@Html.DisplayFor(model => model.Grado)</dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" class="text-center">
                        <input type="hidden" asp-for="AlumnoId" />
                        <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                            <i class="bi bi-trash"></i> Sí, Eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 ms-2">
                            Cancelar
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>