@model ColegioSanJose.Models.Expediente

@{
    ViewData["Title"] = "Editar Expediente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Modificar Registro Académico</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="ExpedienteId" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Estudiante</label>
                                <select asp-for="AlumnoId" class="form-select shadow-sm" asp-items="ViewBag.AlumnoId"></select>
                                <span asp-validation-for="AlumnoId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Materia</label>
                                <select asp-for="MateriaId" class="form-select shadow-sm" asp-items="ViewBag.MateriaId"></select>
                                <span asp-validation-for="MateriaId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Nota Final</label>
                                <input asp-for="NotaFinal" class="form-control shadow-sm" type="number" step="0.1" />
                                <span asp-validation-for="NotaFinal" class="text-danger"></span>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Observaciones</label>
                                <input asp-for="Observaciones" class="form-control shadow-sm" placeholder="Añadir comentario..." />
                                <span asp-validation-for="Observaciones" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm px-4">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="text-center mt-3 text-muted">
                <small><i class="bi bi-info-circle"></i> ID del registro: @Model.ExpedienteId</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}