@model ColegioSanJose.Models.Expediente

@{
    ViewData["Title"] = "Registrar Nota";
}

<div class="container mt-4">
    <h1 class="text-primary"><i class="bi bi-file-earmark-plus"></i> Registrar Nuevo Expediente</h1>
    <p class="text-muted">Asigne una calificación y observaciones a un alumno en una materia específica.</p>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Datos del Registro Académico</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label class="control-label font-weight-bold">Seleccionar Alumno</label>
                            <select asp-for="AlumnoId" class="form-select shadow-sm" asp-items="ViewBag.AlumnoId">
                                <option value="">-- Seleccione un Alumno --</option>
                            </select>
                            <span asp-validation-for="AlumnoId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label font-weight-bold">Materia / Asignatura</label>
                            <select asp-for="MateriaId" class="form-select shadow-sm" asp-items="ViewBag.MateriaId">
                                <option value="">-- Seleccione una Materia --</option>
                            </select>
                            <span asp-validation-for="MateriaId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group mb-3">
                                    <label class="control-label font-weight-bold">Nota Final</label>
                                    <input asp-for="NotaFinal" class="form-control" type="number" step="0.1" placeholder="0.0" />
                                    <span asp-validation-for="NotaFinal" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-group mb-3">
                                    <label class="control-label font-weight-bold">Observaciones</label>
                                    <input asp-for="Observaciones" class="form-control" placeholder="Ej: Excelente desempeño" />
                                    <span asp-validation-for="Observaciones" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group d-flex justify-content-between mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-success px-4 shadow-sm">
                                <i class="bi bi-check-circle"></i> Guardar Expediente
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}