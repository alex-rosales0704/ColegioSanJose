@model ColegioSanJose.Models.Expediente

@{
    ViewData["Title"] = "Detalles del Expediente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-info-circle"></i> Información del Expediente</h4>
                    <span class="badge bg-light text-primary">Folio: #@Model.ExpedienteId</span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold">Estudiante:</div>
                        <div class="col-sm-8 fs-5 text-dark font-weight-bold">
                            @Model.Alumno?.Nombre @Model.Alumno?.Apellido
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold">Materia:</div>
                        <div class="col-sm-8 fs-5 text-dark">
                            <i class="bi bi-book me-2"></i>@Model.Materia?.NombreMateria
                        </div>
                    </div>

                    <hr class="text-light">

                    <div class="row mb-4 align-items-center">
                        <div class="col-sm-4 text-muted font-weight-bold">Calificación Final:</div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.NotaFinal >= 6 ? "bg-success" : "bg-danger") fs-5 px-4 shadow-sm">
                                @Model.NotaFinal
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted font-weight-bold">Observaciones:</div>
                        <div class="col-sm-8 p-3 bg-light rounded border italic">
                            @(string.IsNullOrEmpty(Model.Observaciones) ? "Sin observaciones adicionales." : Model.Observaciones)
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                        <a asp-action="Edit" asp-route-id="@Model?.ExpedienteId" class="btn btn-warning btn-lg shadow-sm">
                            <i class="bi bi-pencil-square"></i> Editar Nota
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Volver a la Lista
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>