@model ColegioSanJose.Models.Materia

@{
    ViewData["Title"] = "Nueva Materia";
}

<div class="container mt-4">
    <h1 class="text-primary"><i class="bi bi-book"></i> Registrar Nueva Materia</h1>
    <p class="text-muted">Ingrese la asignatura y el docente asignado para este ciclo escolar.</p>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Información de la Asignatura</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="form-group mb-3">
                            <label asp-for="NombreMateria" class="control-label fw-bold">Nombre de la Materia</label>
                            <input asp-for="NombreMateria" class="form-control shadow-sm" placeholder="Ej: Matemáticas" />
                            <span asp-validation-for="NombreMateria" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Docente" class="control-label fw-bold">Docente Responsable</label>
                            <input asp-for="Docente" class="form-control shadow-sm" placeholder="Nombre completo del profesor" />
                            <span asp-validation-for="Docente" class="text-danger"></span>
                        </div>

                        <div class="form-group d-flex justify-content-between pt-3 border-top">
                            <button type="submit" class="btn btn-success px-4 shadow-sm">
                                <i class="bi bi-check-circle"></i> Crear Materia
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Volver a la Lista
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}