@model IEnumerable<ColegioSanJose.Models.Materia>

@{
    ViewData["Title"] = "Gestión de Materias";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-primary"><i class="bi bi-book-half"></i> Materias Académicas</h1>
            <p class="text-muted">Administración de asignaturas y personal docente del Colegio San José.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
                <i class="bi bi-journal-plus"></i> Nueva Materia
            </a>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4">Nombre de la Asignatura</th>
                            <th>Docente Responsable</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="align-middle">
                                <td class="ps-4 font-weight-bold">
                                    <i class="bi bi-bookmark-check text-primary me-2"></i>
                                    @Html.DisplayFor(modelItem => item.NombreMateria)
                                </td>
                                <td>
                                    <i class="bi bi-person-workspace me-2 text-muted"></i>
                                    @Html.DisplayFor(modelItem => item.Docente)
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.MateriaId" class="btn btn-warning btn-sm shadow-sm text-dark">
                                            <i class="bi bi-pencil"></i> Editar
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.MateriaId" class="btn btn-primary btn-sm shadow-sm">
                                            <i class="bi bi-eye"></i> Ver
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MateriaId" class="btn btn-danger btn-sm shadow-sm">
                                            <i class="bi bi-trash"></i> Borrar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center mt-5 p-5 bg-light rounded shadow-sm">
            <i class="bi bi-folder-x display-1 text-muted"></i>
            <p class="text-muted fs-4 mt-3">No hay materias registradas. ¡Comienza creando una nueva!</p>
        </div>
    }
</div>