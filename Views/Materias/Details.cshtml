@model ColegioSanJose.Models.Materia

@{
    ViewData["Title"] = "Detalles de la Materia";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-journal-bookmark-fill"></i> Detalles de la Asignatura</h4>
                    <span class="badge bg-light text-primary">ID: @Model.MateriaId</span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Nombre de Materia:</div>
                        <div class="col-sm-8 fs-4 text-dark font-weight-bold">
                            @Html.DisplayFor(model => model.NombreMateria)
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold">Docente Asignado:</div>
                        <div class="col-sm-8 fs-5">
                            <i class="bi bi-person-badge text-primary me-2"></i>@Html.DisplayFor(model => model.Docente)
                        </div>
                    </div>

                    <hr class="text-light">

                    <div class="alert alert-info border-0 shadow-sm">
                        <i class="bi bi-info-circle"></i> Esta materia está disponible para la creación de expedientes académicos.
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                        <a asp-action="Edit" asp-route-id="@Model?.MateriaId" class="btn btn-warning btn-lg shadow-sm">
                            <i class="bi bi-pencil-square"></i> Editar Materia
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
                            <i class="bi bi-arrow-left-circle"></i> Volver a la Lista
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>