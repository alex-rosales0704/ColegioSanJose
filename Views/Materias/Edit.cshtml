@model ColegioSanJose.Models.Materia

@{
    ViewData["Title"] = "Editar Materia";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Modificar Asignatura</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="MateriaId" />

                        <div class="form-group mb-3">
                            <label asp-for="NombreMateria" class="form-label fw-bold">Nombre de la Materia</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-book"></i></span>
                                <input asp-for="NombreMateria" class="form-control shadow-sm" placeholder="Ej: Ciencias Naturales" />
                            </div>
                            <span asp-validation-for="NombreMateria" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Docente" class="form-label fw-bold">Docente a Cargo</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person-workspace"></i></span>
                                <input asp-for="Docente" class="form-control shadow-sm" placeholder="Nombre del profesor" />
                            </div>
                            <span asp-validation-for="Docente" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm px-4">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            <p class="text-center mt-3 text-muted small">
                <i class="bi bi-info-circle"></i> Editando registro ID: @Model.MateriaId
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}